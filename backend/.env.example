# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/emergency_app
DATABASE_ECHO=False

# Redis
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Environment
ENVIRONMENT=development
DEBUG=True
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8081", "http://localhost:19000"]

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@emergencyapp.com
EMAIL_FROM_NAME=Emergency Response App

# SMS Configuration
SMS_API_PROVIDER=africas_talking  # or safaricom
SMS_API_KEY=your-sms-api-key
SMS_API_USERNAME=your-sms-username
SMS_SENDER_ID=EMERGENCY

# Google Maps
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Emergency Contacts
EMERGENCY_POLICE=911
EMERGENCY_MEDICAL=911
EMERGENCY_FIRE=911

# File Upload
MAX_UPLOAD_SIZE=10485760  # 10MB
ALLOWED_EXTENSIONS=jpg,jpeg,png,pdf,mp3,m4a
UPLOAD_DIR=./uploads

# JWT
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Rate Limiting
RATE_LIMIT_ENABLED=True
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# Location Tracking
LOCATION_UPDATE_INTERVAL_SECONDS=10
LOCATION_HISTORY_RETENTION_DAYS=7

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-for-aes-256

# AWS S3 (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
AWS_REGION=us-east-1

# M-Pesa (Optional)
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_SHORTCODE=
MPESA_PASSKEY=
